# Google Places API
# Obtenha em: https://console.cloud.google.com → APIs → Places API
VITE_GOOGLE_PLACES_API_KEY=sua_chave_aqui

# Place ID do AGOMA no Google Maps
# Encontre em: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
VITE_GOOGLE_PLACE_ID=ChIJ...

# iFood Merchant API (opcional — requer conta parceiro iFood)
# Obtenha em: https://portal.ifood.com.br → API → Criar aplicação
VITE_IFOOD_CLIENT_ID=
VITE_IFOOD_CLIENT_SECRET=
VITE_IFOOD_MERCHANT_ID=
